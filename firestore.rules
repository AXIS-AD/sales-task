rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedDomainUser() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@shibuya-ad\\.com$');
    }

    match /salesTaskApps/{appId}/{document=**} {
      allow read, write: if isAllowedDomainUser();
    }
  }
}
